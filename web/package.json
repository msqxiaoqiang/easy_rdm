{
  "name": "easy-rdm",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "VITE_PLATFORM=web vite --host",
    "dev:gm": "vite --mode gm --host --port 5174",
    "build": "vue-tsc --noEmit && vite build",
    "build:web": "VITE_PLATFORM=web vue-tsc --noEmit && VITE_PLATFORM=web vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.57.0",
    "@codemirror/lang-json": "^6.0.2",
    "codemirror": "^6.0.2",
    "gm-app-sdk": "^1.0.0",
    "pinia": "^2.1.7",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vue": "^3.4.0",
    "vue-i18n": "^9.9.0"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "typescript": "~5.3.0",
    "vite": "^5.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^1.8.0"
  }
}
